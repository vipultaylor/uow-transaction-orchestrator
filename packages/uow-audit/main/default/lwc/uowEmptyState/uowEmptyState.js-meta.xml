<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>UoW: Empty State</masterLabel>
    <description>Reusable empty state component with configurable icon, heading, and body text</description>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__RecordPage,lightning__HomePage,lightning__FlowScreen">
            <property name="iconName" type="String" default="utility:info" label="Icon Name" description="Lightning icon name (e.g., utility:success, utility:warning)"/>
            <property name="heading" type="String" default="" label="Heading" description="Main heading text"/>
            <property name="body" type="String" default="" label="Body" description="Body/description text"/>
            <property name="iconSize" type="String" default="large" label="Icon Size" description="Icon size: xx-small, x-small, small, medium, large" datasource="xx-small,x-small,small,medium,large"/>
            <property name="iconVariant" type="String" default="" label="Icon Variant" description="Icon variant: bare, brand, inverse, error, success, warning" datasource=",bare,brand,inverse,error,success,warning"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
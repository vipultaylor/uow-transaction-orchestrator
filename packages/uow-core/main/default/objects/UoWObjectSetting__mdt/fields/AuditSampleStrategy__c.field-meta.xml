<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>AuditSampleStrategy__c</fullName>
    <businessStatus>Active</businessStatus>
    <description>Strategy for selecting which records to include in snapshot</description>
    <fieldManageability>SubscriberControlled</fieldManageability>
    <inlineHelpText>FIRST_N = first records, LAST_N = last records, RANDOM = random sampling. Default: FIRST_N</inlineHelpText>
    <label>Audit Sample Strategy</label>
    <required>false</required>
    <securityClassification>Internal</securityClassification>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>FIRST_N</fullName>
                <default>true</default>
                <label>First N Records</label>
            </value>
            <value>
                <fullName>LAST_N</fullName>
                <default>false</default>
                <label>Last N Records</label>
            </value>
            <value>
                <fullName>RANDOM</fullName>
                <default>false</default>
                <label>Random Sampling</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>

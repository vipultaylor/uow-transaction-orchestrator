<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>MaskingStrategy__c</fullName>
    <businessStatus>Active</businessStatus>
    <description>Masking strategy to apply: FULL (***), PARTIAL (***6789), EMAIL (j***@***.com), HASH (SHA256 hash), REDACT (null), CUSTOM (use MaskingClass__c).</description>
    <fieldManageability>SubscriberControlled</fieldManageability>
    <inlineHelpText>Select masking type: FULL replaces all chars with *, PARTIAL shows some chars (configure in Masking Options), EMAIL masks email format, HASH converts to SHA-256, REDACT returns null.</inlineHelpText>
    <label>Masking Strategy</label>
    <required>true</required>
    <securityClassification>Internal</securityClassification>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>FULL</fullName>
                <default>true</default>
                <label>Full Masking</label>
            </value>
            <value>
                <fullName>PARTIAL</fullName>
                <default>false</default>
                <label>Partial Masking</label>
            </value>
            <value>
                <fullName>EMAIL</fullName>
                <default>false</default>
                <label>Email Masking</label>
            </value>
            <value>
                <fullName>HASH</fullName>
                <default>false</default>
                <label>Hash Masking</label>
            </value>
            <value>
                <fullName>REDACT</fullName>
                <default>false</default>
                <label>Redact (Null)</label>
            </value>
            <value>
                <fullName>CUSTOM</fullName>
                <default>false</default>
                <label>Custom Strategy</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
